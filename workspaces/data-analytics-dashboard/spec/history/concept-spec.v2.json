    { "screen_id": "main-dashboard", "need": "Top header bar", "component": "Box", "gap": false },
    { "screen_id": "main-dashboard", "need": "User avatar in header", "component": "Avatar", "variant": "subtle", "gap": false },
    { "screen_id": "main-dashboard", "need": "Notification bell", "component": "Button", "variant": "ghost", "gap": false },
    { "screen_id": "main-dashboard", "need": "KPI stat cards", "component": "Card", "variant": "elevated", "gap": false },
    { "screen_id": "main-dashboard", "need": "KPI change badge (positive/negative)", "component": "Badge", "variant": "subtle", "gap": false },
    { "screen_id": "main-dashboard", "need": "Trend line chart", "component": "recharts/LineChart", "gap": true },
    { "screen_id": "main-dashboard", "need": "Distribution donut chart", "component": "recharts/PieChart", "gap": true },

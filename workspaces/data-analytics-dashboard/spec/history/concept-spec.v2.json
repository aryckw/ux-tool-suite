{
  "schema_version": "1.0",
  "id": "data-analytics-dashboard",
  "version": 2,
  "fidelity_stage": "draft",
  "knowledge_pack_ref": {
    "library_name": "chakra-ui",
    "library_version": "3.36.0"
  },
  "intent": {
    "goal": "Analytics dashboard for business intelligence: KPI cards, trend charts, filterable data tables, and alert management",
    "personas": [
      { "name": "Business Analyst", "needs": "Power user, daily use, needs deep drill-down into data and configurable views" },
      { "name": "Executive", "needs": "Occasional user, mobile-friendly, needs high-level KPI overview and trend summaries" }
    ],
    "success_criteria": [
      "KPI metrics visible above the fold",
      "Charts render trend data for configurable time range",
      "Data table supports column sort and row filter",
      "Alert center shows active threshold violations"
    ],
    "constraints": {
      "platforms": ["web"],
      "devices": ["desktop-1440px", "tablet-768px"],
      "a11y_target": "WCAG 2.1 AA",
      "brand": "Chakra UI v3 design tokens"
    },
    "non_goals": [
      "Mobile-native",
      "Real-time websocket push",
      "Admin/settings screens"
    ]
  },
  "elicitation_log": [

    { "screen_id": "reports", "need": "Column visibility menu", "component": "Menu", "gap": false },
    { "screen_id": "reports", "need": "Search input", "component": "Input", "variant": "outline", "gap": false },
    { "screen_id": "reports", "need": "Export button", "component": "Button", "variant": "solid", "gap": false },

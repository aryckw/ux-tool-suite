  "information_architecture": {
    "screens": [
      { "id": "main-dashboard", "name": "Main Dashboard", "purpose": "KPI overview, trend charts, quick filters" },
      { "id": "reports", "name": "Reports / Data Table", "purpose": "Tabular breakdown with sort/filter/export" },
      { "id": "alert-center", "name": "Alert Center", "purpose": "Active threshold violations and notification history" }
    ],
    "navigation": [
      { "from": "main-dashboard", "to": "reports", "trigger": "Sidebar nav item click" },
      { "from": "main-dashboard", "to": "alert-center", "trigger": "Sidebar nav item click or notification bell" },
      { "from": "reports", "to": "main-dashboard", "trigger": "Sidebar nav item click" },
      { "from": "alert-center", "to": "main-dashboard", "trigger": "Sidebar nav item click" }
    ],
    "flows": [
      {
        "name": "KPI drill-down",
        "steps": ["View KPI card on main dashboard", "Click KPI card", "Navigate to filtered Reports view"]
      },
      {
        "name": "Alert triage",
        "steps": ["See notification badge on bell", "Navigate to Alert Center", "Review alert details in drawer", "Acknowledge or snooze alert"]
      }
    ]
  },
  "composition": [
    {
      "screen_id": "main-dashboard",
      "regions": [
        { "name": "sidebar", "responsive": "hidden on mobile, 220px on desktop" },
        { "name": "header", "responsive": "full width, 64px height" },
        { "name": "kpi-row", "responsive": "4-col grid on desktop, 2-col on tablet" },
        { "name": "charts-row", "responsive": "2/3 + 1/3 split on desktop, stacked on tablet" },
        { "name": "filters-row", "responsive": "inline flex on desktop, stacked on tablet" },
        { "name": "recent-events-table", "responsive": "full width" }
      ],
      "breakpoints": ["1440px", "768px"]
    },
    {
      "screen_id": "reports",
      "regions": [
        { "name": "sidebar", "responsive": "hidden on mobile, 220px on desktop" },
        { "name": "header", "responsive": "full width, 64px height" },
        { "name": "table-toolbar", "responsive": "full width" },
        { "name": "data-table", "responsive": "full width, horizontally scrollable on tablet" }
      ],
      "breakpoints": ["1440px", "768px"]
    },
    {
      "screen_id": "alert-center",
      "regions": [
        { "name": "sidebar", "responsive": "hidden on mobile, 220px on desktop" },
        { "name": "header", "responsive": "full width, 64px height" },
        { "name": "alert-summary-bar", "responsive": "full width" },
        { "name": "alert-list", "responsive": "full width" },
        { "name": "alert-detail-drawer", "responsive": "end drawer, full height" }
      ],
      "breakpoints": ["1440px", "768px"]
    }
  ],
  "component_bindings": [

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://company.example/schemas/knowledge-pack.schema.json",
  "title": "Knowledge Pack",
  "description": "Knowledge Pack produced by Phase 0 library extraction",
  "type": "object",
  "required": ["meta", "tech_stack", "components"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["library_name", "library_version"],
      "properties": {
        "library_name": { "type": "string" },
        "library_version": { "type": "string" },
        "source_commit": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "extractor_version": { "type": "string" },
        "coverage_confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "tech_stack": {
      "type": "object",
      "properties": {
        "framework": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "version": { "type": "string" }
          }
        },
        "language": { "type": "string", "enum": ["ts", "js"] },
        "bundler": { "type": "string" },
        "package_manager": { "type": "string" },
        "node_version": { "type": "string" },
        "styling_system": { "type": "string", "enum": ["tailwind", "css-vars", "css-in-js", "other"] },
        "peer_dependencies": { "type": "array", "items": { "type": "string" } },
        "build_commands": {
          "type": "object",
          "properties": {
            "dev": { "type": "string" },
            "build": { "type": "string" },
            "test": { "type": "string" }
          }
        },
        "supported_targets": { "type": "array", "items": { "type": "string" } }
      }
    },
    "design_tokens": {
      "type": "object",
      "properties": {
        "source": {
          "type": "object",
          "properties": {
            "file": { "type": "string" },
            "format": { "type": "string" }
          }
        },
        "color": {
          "type": "object",
          "properties": {
            "light": { "type": "object" },
            "dark": { "type": "object" }
          },
          "additionalProperties": true
        },
        "typography": {
          "type": "object",
          "properties": {
            "light": { "type": "object" },
            "dark": { "type": "object" }
          },
          "additionalProperties": true
        },
        "spacing": {
          "type": "object",
          "properties": {
            "light": { "type": "object" },
            "dark": { "type": "object" }
          },
          "additionalProperties": true
        },
        "radius": {
          "type": "object",
          "properties": {
            "light": { "type": "object" },
            "dark": { "type": "object" }
          },
          "additionalProperties": true
        },
        "shadow": {
          "type": "object",
          "properties": {
            "light": { "type": "object" },
            "dark": { "type": "object" }
          },
          "additionalProperties": true
        },
        "zindex": {
          "type": "object",
          "properties": {
            "light": { "type": "object" },
            "dark": { "type": "object" }
          },
          "additionalProperties": true
        },
        "breakpoints": {
          "type": "object",
          "properties": {
            "light": { "type": "object" },
            "dark": { "type": "object" }
          },
          "additionalProperties": true
        },
        "motion": {
          "type": "object",
          "properties": {
            "light": { "type": "object" },
            "dark": { "type": "object" }
          },
          "additionalProperties": true
        }
      }
    },
    "design_principles": {
      "type": "object",
      "properties": {
        "principles": { "type": "array", "items": { "type": "string" } },
        "voice_tone": { "type": "string" },
        "density": { "type": "string" },
        "layout_grids": { "type": "array", "items": { "type": "string" } },
        "brand_constraints": { "type": "string" },
        "do": { "type": "array", "items": { "type": "string" } },
        "dont": { "type": "array", "items": { "type": "string" } }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "category": { "type": "string" },
          "status": { "type": "string", "enum": ["stable", "beta", "deprecated"] },
          "import": {
            "type": "object",
            "properties": {
              "package": { "type": "string" },
              "export": { "type": "string" },
              "path": { "type": "string" }
            }
          },
          "anatomy": {
            "type": "object",
            "properties": {
              "parts": { "type": "array", "items": { "type": "string" } }
            }
          },
          "slots": { "type": "array", "items": { "type": "string" } },
          "props": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "type": { "type": "string" },
                "required": { "type": "boolean" },
                "default": {},
                "enum": { "type": "array" },
                "description": { "type": "string" }
              }
            }
          },
          "variants": { "type": "array", "items": { "type": "string" } },
          "states": { "type": "array", "items": { "type": "string" } },
          "behaviors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "trigger": { "type": "string" },
                "result": { "type": "string" }
              }
            }
          },
          "keyboard_map": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "key": { "type": "string" },
                "action": { "type": "string" }
              }
            }
          },
          "accessibility": {
            "type": "object",
            "properties": {
              "role": { "type": "string" },
              "aria": { "type": "array", "items": { "type": "string" } },
              "focus_management": { "type": "string" },
              "wcag_notes": { "type": "string" }
            }
          },
          "composition": {
            "type": "object",
            "properties": {
              "composed_of": { "type": "array", "items": { "type": "string" } },
              "commonly_used_with": { "type": "array", "items": { "type": "string" } }
            }
          },
          "tokens_used": { "type": "array", "items": { "type": "string" } },
          "examples": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "code": { "type": "string" },
                "story_id": { "type": "string" }
              }
            }
          },
          "source_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "components": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "app_shell": {
      "type": "object",
      "properties": {
        "routing_lib": { "type": "string" },
        "theme_provider": { "type": "string" },
        "layout_primitives": { "type": "array", "items": { "type": "string" } },
        "recommended_structure": { "type": "string" }
      }
    },
    "capabilities": {
      "type": "array",
      "description": "What the library covers",
      "items": { "type": "string" }
    },
    "gaps": {
      "type": "array",
      "description": "What the library does NOT cover",
      "items": { "type": "string" }
    },
    "coverage_report": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "component": { "type": "string" },
          "extracted": { "type": "boolean" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "missing": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
